generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUB_ADMIN
  STUDENT
  PARENT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  role         Role
  phone        String?
  profilePic   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student      Student?
  teacher      Teacher?
  parent       Parent?
  announcements Announcement[] @relation("CreatedBy")
}

model Student {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  rollNumber   String   @unique
  batchId      String
  batch        Batch    @relation(fields: [batchId], references: [id])
  parentId     String?
  parent       Parent?  @relation(fields: [parentId], references: [id])
  fees         Fee[]
  attendance   Attendance[]
  results      Result[]
  diaryEntries StudentDiary[]
}

model Teacher {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      String
  qualification String?
  batches      Batch[]  @relation("TeacherBatches")
  leaves       Leave[]
  payroll      Payroll[]
  timetable    Timetable[]
  assignments  Assignment[]
}

model Parent {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  children     Student[]
}

model Batch {
  id           String   @id @default(cuid())
  name         String
  courseId      String
  course       Course   @relation(fields: [courseId], references: [id])
  startDate    DateTime
  endDate      DateTime?
  teacherId    String?
  teacher      Teacher? @relation("TeacherBatches", fields: [teacherId], references: [id])
  students     Student[]
  videos       Video[]
  notes        Note[]
  timetable    Timetable[]
  assignments  Assignment[]
  exams        Exam[]
  liveClasses  LiveClass[]
  onlineExams  OnlineExam[]
}

model Course {
  id           String   @id @default(cuid())
  name         String
  description  String?
  batches      Batch[]
  modules      Module[]
}

model Attendance {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  date         DateTime @default(now())
  status       String   // PRESENT, ABSENT, LATE
  markedBy     String   // teacherId
  createdAt    DateTime @default(now())
}

model Fee {
  id              String   @id @default(cuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  totalFees       Float
  paidAmount      Float    @default(0)
  dueDate         DateTime
  status          String   // PAID, PENDING, OVERDUE, PARTIAL
  reminderSentAt  DateTime?
  payments        Payment[]
  emiPlans        EMIPlan[]
}

model Payment {
  id            String   @id @default(cuid())
  feeId         String
  fee           Fee      @relation(fields: [feeId], references: [id], onDelete: Cascade)
  amount        Float
  method        String   // CASH, ONLINE, CARD
  transactionId String?
  receiptNo     String   @unique
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([feeId])
  @@index([status])
}

model Video {
  id           String   @id @default(cuid())
  title        String
  url          String
  batchId      String
  batch        Batch    @relation(fields: [batchId], references: [id])
  uploadedBy   String
  duration     Int?
  createdAt    DateTime @default(now())
  engagements  VideoEngagement[]
}

model Note {
  id           String   @id @default(cuid())
  title        String
  fileUrl      String
  batchId      String
  batch        Batch    @relation(fields: [batchId], references: [id])
  type         String   // NOTES, WORKSHEET, HOMEWORK
  uploadedBy   String
  createdAt    DateTime @default(now())
}

model Announcement {
  id           String   @id @default(cuid())
  title        String
  content      String
  targetRole   Role?
  createdBy    String
  creator      User     @relation("CreatedBy", fields: [createdBy], references: [id])
  createdAt    DateTime @default(now())
}

model Timetable {
  id           String   @id @default(cuid())
  batchId      String
  batch        Batch    @relation(fields: [batchId], references: [id])
  day          String   // MONDAY, TUESDAY, ...
  subject      String
  startTime    String
  endTime      String
  teacherId    String?
  teacher      Teacher? @relation(fields: [teacherId], references: [id])
}

model Assignment {
  id           String   @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime
  fileUrl      String?
  batchId      String
  batch        Batch    @relation(fields: [batchId], references: [id])
  createdBy    String
  teacher      Teacher  @relation(fields: [createdBy], references: [id])
  createdAt    DateTime @default(now())
}

model Exam {
  id           String   @id @default(cuid())
  name         String
  date         DateTime
  maxMarks     Int
  batchId      String
  batch        Batch    @relation(fields: [batchId], references: [id])
  results      Result[]
}

model Result {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  examId       String
  exam         Exam     @relation(fields: [examId], references: [id])
  marksObtained Float
  feedback     String?
}

model Leave {
  id           String   @id @default(cuid())
  teacherId    String
  teacher      Teacher  @relation(fields: [teacherId], references: [id])
  startDate    DateTime
  endDate      DateTime
  reason       String
  status       String   // PENDING, APPROVED, REJECTED
}

model Payroll {
  id           String   @id @default(cuid())
  teacherId    String
  teacher      Teacher  @relation(fields: [teacherId], references: [id])
  month        Int
  year         Int
  amount       Float
  deductions   Float    @default(0)
  netAmount    Float
  paid         Boolean  @default(false)
  paidAt       DateTime?
}

model Expense {
  id           String   @id @default(cuid())
  description  String
  amount       Float
  date         DateTime @default(now())
  category     String
  createdBy    String
}

model StudentDiary {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  date         DateTime @default(now())
  content      String
  type         String   // HOMEWORK, REMARK, BEHAVIOR
  createdBy    String
}

model Notification {
  id          String   @id @default(cuid())
  type        String   // FEE_PAYMENT, ANNOUNCEMENT
  title       String
  message     String
  isRead      Boolean  @default(false)
  targetRole  Role?
  paymentId   String?
  studentId   String?
  studentName String?
  amount      Float?
  createdAt   DateTime @default(now())
}

// ─── RBAC & Activity Logs ───────────────────────────────────────────────
model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@unique([role, permissionId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entity     String
  entityId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  @@index([userId])
  @@index([createdAt])
}

// ─── Course Hierarchy: Module & Lesson ──────────────────────────────────
model Module {
  id            String   @id @default(cuid())
  courseId       String
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  order          Int      @default(0)
  dripDate       DateTime?
  prerequisiteId String?
  prerequisite   Module?    @relation("ModulePrerequisite", fields: [prerequisiteId], references: [id])
  dependents     Module[]   @relation("ModulePrerequisite")
  lessons        Lesson[]
  createdAt      DateTime @default(now())
}

model Lesson {
  id          String   @id @default(cuid())
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  content     String?
  videoUrl    String?
  duration    Int?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

// ─── Video Engagement Analytics ─────────────────────────────────────────
model VideoEngagement {
  id          String   @id @default(cuid())
  videoId     String
  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  studentId   String
  watchTime   Int      @default(0)
  completed   Boolean  @default(false)
  dropOffAt   Int?
  lastWatched DateTime @default(now())
  @@unique([videoId, studentId])
}

// ─── Live Classes ───────────────────────────────────────────────────────
model LiveClass {
  id            String   @id @default(cuid())
  title         String
  description   String?
  batchId       String
  batch         Batch    @relation(fields: [batchId], references: [id])
  hostId        String
  platform      String
  meetingUrl    String?
  meetingId     String?
  scheduledAt   DateTime
  duration      Int
  status        String   @default("SCHEDULED")
  recordingUrl  String?
  createdAt     DateTime @default(now())
  chats         LiveChat[]
  polls         LivePoll[]
  handRaises    HandRaise[]
}

model LiveChat {
  id          String   @id @default(cuid())
  liveClassId String
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  userId      String
  userName    String
  message     String
  createdAt   DateTime @default(now())
}

model HandRaise {
  id          String   @id @default(cuid())
  liveClassId String
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  userId      String
  userName    String
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model LivePoll {
  id          String   @id @default(cuid())
  liveClassId String
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  question    String
  options     Json
  responses   Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─── Doubt / Discussion Forum ───────────────────────────────────────────
model Discussion {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  body        String
  userId      String
  userName    String
  userRole    Role
  replies     DiscussionReply[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DiscussionReply {
  id           String     @id @default(cuid())
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  body         String
  userId       String
  userName     String
  userRole     Role
  parentId     String?
  parent       DiscussionReply?  @relation("ReplyThread", fields: [parentId], references: [id])
  children     DiscussionReply[] @relation("ReplyThread")
  createdAt    DateTime   @default(now())
}

// ─── Chat (Student-Teacher) ────────────────────────────────────────────
model ChatMessage {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  @@index([senderId, receiverId])
}

// ─── Fee Enhancements: Subscriptions, Coupons, EMI ─────────────────────
model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String
  amount      Float
  duration    Int
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  discountType String
  discountValue Float
  maxUses     Int      @default(0)
  usedCount   Int      @default(0)
  validFrom   DateTime
  validTo     DateTime
  isActive    Boolean  @default(true)
}

model EMIPlan {
  id            String   @id @default(cuid())
  feeId         String
  fee           Fee      @relation(fields: [feeId], references: [id], onDelete: Cascade)
  totalAmount   Float
  installments  Int
  amountPerEMI  Float
  paidCount     Int      @default(0)
  nextDueDate   DateTime
  createdAt     DateTime @default(now())
}

// ─── MCQ Test Engine ────────────────────────────────────────────────────
model QuestionBank {
  id          String   @id @default(cuid())
  courseId    String
  question    String
  options     Json
  correctIndex Int
  difficulty  String   @default("MEDIUM")
  tags        String?
  createdAt   DateTime @default(now())
}

model OnlineExam {
  id             String   @id @default(cuid())
  title          String
  batchId        String
  batch          Batch    @relation(fields: [batchId], references: [id])
  duration       Int
  totalMarks     Int
  randomize      Boolean  @default(false)
  proctoring     Boolean  @default(false)
  startTime      DateTime
  endTime        DateTime
  questions      ExamQuestion[]
  submissions    ExamSubmission[]
  createdAt      DateTime @default(now())
}

model ExamQuestion {
  id           String     @id @default(cuid())
  examId       String
  exam         OnlineExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionBankId String?
  question     String
  options      Json
  correctIndex Int
  marks        Int        @default(1)
  order        Int        @default(0)
}

model ExamSubmission {
  id           String     @id @default(cuid())
  examId       String
  exam         OnlineExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId    String
  answers      Json
  score        Float?
  tabSwitches  Int        @default(0)
  submittedAt  DateTime   @default(now())
  @@unique([examId, studentId])
}

// ─── Gamification ───────────────────────────────────────────────────────
model Badge {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String?
  criteria    String
  studentBadges StudentBadge[]
}

model StudentBadge {
  id        String   @id @default(cuid())
  studentId String
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  earnedAt  DateTime @default(now())
  @@unique([studentId, badgeId])
}

model StudentStreak {
  id           String   @id @default(cuid())
  studentId    String   @unique
  currentStreak Int     @default(0)
  longestStreak Int     @default(0)
  lastActiveDate DateTime?
}

model Certificate {
  id          String   @id @default(cuid())
  studentId   String
  courseId     String
  courseName  String
  studentName String
  issuedAt    DateTime @default(now())
  certificateUrl String?
}

// ─── Parent Engagement ──────────────────────────────────────────────────
model ParentMeeting {
  id          String   @id @default(cuid())
  parentId    String
  teacherId   String
  scheduledAt DateTime
  status      String   @default("SCHEDULED")
  notes       String?
  createdAt   DateTime @default(now())
}

// ─── Rule-Based Notification Engine ────────────────────────────────────
model NotificationRule {
  id          String   @id @default(cuid())
  name        String
  trigger     String
  condition   Json
  template    String
  targetRole  Role?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─── Data Access Tracking (Security) ───────────────────────────────────
model DataAccessLog {
  id         String   @id @default(cuid())
  userId     String
  resource   String
  action     String
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  @@index([userId, createdAt])
}
